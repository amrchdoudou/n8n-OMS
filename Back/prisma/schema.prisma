// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String
  storeName String
  whatsappNumber  String?
  email     String?  @unique
  password  String   @default("password")
  createdAt DateTime @default(now())
  deliveryProvider String?
  apiKey String?
  webhookUrl String?

  orders    Order[]
}

enum OrderStatus {
  pending
  confirmed
  pushed
  in_transit
  delivered
  cancelled
  failed
  returned
  READY
  PICKUP
  TO_STATION
  IN_STATION
  TO_WILAYA
  PREPARING
  IN_TRANSIT
  SUSPENDED
  DELIVERED
  RETURNED
}

enum DeliveryType {
  domicile
  stopdesk
}

model Order {
  id               Int          @id @default(autoincrement())
  shopifyId        String?
  customer         String
  phone            String
  location         String
  product          String
  price            Float
  currency         String       @default("DZD")
  whatsappAttempts Int          @default(0)
  status           OrderStatus  @default(pending)
  trackingId       String?
  deliveryType     DeliveryType @default(domicile)
  webhookUrl       String?
  createdAt        DateTime     @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}
